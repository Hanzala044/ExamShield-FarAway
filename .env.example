# Copy to .env to override docker-compose defaults.

# Backend
DATABASE_URL=postgresql+psycopg2://examshield:examshield@db:5432/examshield
JWT_SECRET=dev-only-change-me

# IntegrityAI — flip to real Claude (deterministic engine is default)
AI_USE_CLAUDE=false
ANTHROPIC_API_KEY=

# ChainLedger — simulated by default. Point at a real RPC + contract to go live.
CHAIN_SIMULATED=true

# Frontend
VITE_API_BASE=http://localhost:8000
